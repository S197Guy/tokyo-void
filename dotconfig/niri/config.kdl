// tokyo-void Niri Configuration
// Theme: Tokyo Night Storm

prefer-no-csd

layout {
    gaps 8
    center-focused-column "never"

    border {
        width 2
        active-color "#7aa2f7"
        inactive-color "#24283b"
    }

    focus-ring {
        width 2
        active-color "#7aa2f7"
        inactive-color "#24283b"
    }
}

input {
    mod-key "Super"
    focus-follows-mouse
    keyboard {
        xkb {
            layout "us"
        }
    }

    touchpad {
        tap
        natural-scroll
    }
}

output "eDP-1" {
    mode "1920x1080@60.0"
    scale 1.0
}

window-rule {
    match app-id="firefox"
    open-maximized true
}

window-rule {
    match app-id="Alacritty" title="ranger"
    open-maximized true
}

binds {
    Mod+Shift+SLASH { show-hotkey-overlay; }

    Mod+Return { spawn "/usr/bin/alacritty"; }
    Mod+T { spawn "/usr/bin/alacritty"; }
    Mod+Space { spawn "/usr/bin/fuzzel"; }
    
    // New Bindings
    Mod+E { spawn "/usr/bin/alacritty" "-t" "ranger" "-e" "ranger"; }
    Mod+B { spawn "/usr/bin/firefox"; }
    
    Mod+Q { close-window; }
    
    // Vim-like movement
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+J { focus-workspace-down; }
    Mod+K { focus-workspace-up; }

    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }
    Mod+Shift+J { move-column-to-workspace-down; }
    Mod+Shift+K { move-column-to-workspace-up; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }

    Mod+Shift+E { quit; }
    Mod+Shift+Q { quit; }
    
    // Laptop Controls
    XF86MonBrightnessUp { spawn "/usr/bin/brightnessctl" "set" "5%+"; }
    XF86MonBrightnessDown { spawn "/usr/bin/brightnessctl" "set" "5%-"; }
}

spawn-at-startup "sh" "-c" "/usr/bin/swww-daemon"
spawn-at-startup "sh" "-c" "sleep 1 && /usr/bin/swww img ~/.config/wallpaper.jpg"
spawn-at-startup "sh" "-c" "sleep 1 && /usr/bin/quickshell"
